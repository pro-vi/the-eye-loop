            "title": "HealthLab Dashboard",
            "summary": "A personal dashboard for tracking long-term health experiments with experiment cards, metrics overview, and quick-log interface.",
            "html": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>HealthLab Dashboard</title><style>:root{--bg:#FFF8F0;--card:#FFF;--accent:#FF8C69;--text:#4A3E38;--muted:#A1887F;--radius:16px;--space:20px;--border:#E8DDD5}*{margin:0;padding:0;box-sizing:border-box}body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:16px;line-height:1.5;padding:var(--space)}main{max-width:375px;margin:0 auto}.header{margin-bottom:32px}.header h1{font-size:28px;font-weight:600;margin-bottom:8px}.header p{font-size:14px;color:var(--muted)}.section{margin-bottom:28px}.section-title{font-size:20px;font-weight:600;margin-bottom:16px;color:var(--text)}.metrics-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}.metric-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;text-align:center}.metric-value{font-size:24px;font-weight:700;color:var(--accent);margin-bottom:4px}.metric-label{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.5px}.experiments-list{display:flex;flex-direction:column;gap:12px}.experiment-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;display:flex;justify-content:space-between;align-items:flex-start}.experiment-info h3{font-size:16px;font-weight:600;margin-bottom:6px;color:var(--text)}.experiment-info p{font-size:13px;color:var(--muted);margin-bottom:8px}.experiment-status{display:inline-block;font-size:11px;padding:4px 10px;background:#F0E8E0;color:var(--text);border-radius:8px;font-weight:500}.experiment-days{font-size:18px;font-weight:700;color:var(--accent);text-align:right}.quick-log{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px}.log-input{width:100%;padding:12px;border:1px solid var(--border);border-radius:10px;font-size:14px;margin-bottom:12px;font-family:inherit;color:var(--text)}.log-input::placeholder{color:var(--muted)}.log-button{width:100%;padding:12px;background:var(--accent);color:#FFF;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:opacity 0.2s}.log-button:active{opacity:0.85}</style></head><body><main><div class=\"header\"><h1>HealthLab</h1><p>Track your experiments, measure your progress</p></div><section class=\"section\"><h2 class=\"section-title\">Overview</h2><div class=\"metrics-grid\"><div class=\"metric-card\"><div class=\"metric-value\">4</div><div class=\"metric-label\">Active Experiments</div></div><div class=\"metric-card\"><div class=\"metric-value\">23</div><div class=\"metric-label\">Days Tracked</div></div></div></section><section class=\"section\"><h2 class=\"section-title\">Current Experiments</h2><div class=\"experiments-list\"><div class=\"experiment-card\"><div class=\"experiment-info\"><h3>Morning Meditation</h3><p>10 min daily practice</p><span class=\"experiment-status\">Active</span></div><div class=\"experiment-days\">18d</div></div><div class=\"experiment-card\"><div class=\"experiment-info\"><h3>Sleep Tracking</h3><p>Monitor sleep quality</p><span class=\"experiment-status\">Active</span></div><div class=\"experiment-days\">23d</div></div><div class=\"experiment-card\"><div class=\"experiment-info\"><h3>Water Intake</h3><p>8 glasses per day</p><span class=\"experiment-status\">Active</span></div><div class=\"experiment-days\">12d</div></div></div></section><section class=\"section\"><h2 class=\"section-title\">Quick Log</h2><div class=\"quick-log\"><input type=\"text\" class=\"log-input\" placeholder=\"Log today's observation...\"><button class=\"log-button\">Save Entry</button></div></section></main></body></html>",
