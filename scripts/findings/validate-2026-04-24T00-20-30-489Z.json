x;margin-bottom:12px;font-family:inherit;color:var(--text)}.log-input::placeholder{color:var(--muted)}.log-button{width:100%;padding:12px;background:var(--accent);color:#FFF;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:opacity 0.2s}.log-button:active{opacity:0.85}</style></head><body><main><div class=\"header\"><h1>HealthLab</h1><p>Track your experiments, measure your progress</p></div><section class=\"section\"><h2 class=\"section-title\">Overview</h2><div class=\"metrics-grid\"><div class=\"metric-card\"><div class=\"metric-value\">4</div><div class=\"metric-label\">Active Experiments</div></div><div class=\"metric-card\"><div class=\"metric-value\">23</div><div class=\"metric-label\">Days Tracked</div></div></div></section><section class=\"section\"><h2 class=\"section-title\">Current Experiments</h2><div class=\"experiments-list\"><div class=\"experiment-card\"><div class=\"experiment-info\"><h3>Morning Meditation</h3><p>10 min daily practice</p><span class=\"experiment-status\">Active</span></div><div class=\"experiment-days\">18d</div></div><div class=\"experiment-card\"><div class=\"experiment-info\"><h3>Sleep Tracking</h3><p>Monitor sleep quality</p><span class=\"experiment-status\">Active</span></div><div class=\"experiment-days\">23d</div></div><div class=\"experiment-card\"><div class=\"experiment-info\"><h3>Water Intake</h3><p>8 glasses per day</p><span class=\"experiment-status\">Active</span></div><div class=\"experiment-days\">12d</div></div></div></section><section class=\"section\"><h2 class=\"section-title\">Quick Log</h2><div class=\"quick-log\"><input type=\"text\" class=\"log-input\" placeholder=\"Log today's observation...\"><button class=\"log-button\">Save Entry</button></div></section></main></body></html>",
