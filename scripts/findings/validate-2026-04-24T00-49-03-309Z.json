n;\n      gap: 8px;\n    }\n    .card-title {\n      font-size: 16px;\n      font-weight: 600;\n      color: var(--text);\n    }\n    .card-desc {\n      font-size: 14px;\n      color: var(--muted);\n    }\n    .card-meta {\n      font-size: 12px;\n      color: rgba(74, 62, 56, 0.5);\n      margin-top: 4px;\n    }\n    .quick-actions {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 12px;\n    }\n    .action-btn {\n      background: var(--card);\n      border: 2px solid var(--accent);\n      border-radius: var(--radius);\n      padding: 16px 12px;\n      text-align: center;\n      font-size: 14px;\n      font-weight: 600;\n      color: var(--accent);\n      cursor: pointer;\n      transition: all 0.2s;\n    }\n    .action-btn:active {\n      background: rgba(255, 140, 105, 0.1);\n    }\n    .primary-btn {\n      background: var(--accent);\n      color: #FFF;\n      border: none;\n      padding: 16px;\n      border-radius: var(--radius);\n      font-size: 16px;\n      font-weight: 600;\n      cursor: pointer;\n      width: 100%;\n      transition: all 0.2s;\n    }\n    .primary-btn:active {\n      opacity: 0.9;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Workspace</h1>\n      <div class=\"header-action\">⚙</div>\n    </div>\n\n    <div class=\"section\">\n      <div class=\"section-title\">Active Projects</div>\n      <div class=\"card\">\n        <div class=\"card-title\">Content Strategy Q1</div>\n        <div class=\"card-desc\">Outline and research phase</div>\n        <div class=\"card-meta\">3 tasks • Due Jan 28</div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">Product Documentation</div>\n        <div class=\"card-desc\">API reference and guides</div>\n        <div class=\"card-meta\">5 tasks • Due Feb 5</div>\n      </div>\n    </div>\n\n    <div class=\"section\">\n      <div class=\"section-title\">Quick Actions</div>\n      <div class=\"qui